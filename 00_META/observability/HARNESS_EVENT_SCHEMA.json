{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chromatic Harness Event",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "event_type",
    "severity",
    "category",
    "message",
    "source",
    "status"
  ],
  "properties": {
    "event_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "repo": { "type": "string" },
    "workspace": { "type": "string" },
    "event_type": {
      "type": "string",
      "enum": ["info", "warning", "error", "incident", "collision", "learning"]
    },
    "severity": {
      "type": "string",
      "enum": ["info", "low", "medium", "high", "critical"]
    },
    "category": {
      "type": "string",
      "enum": [
        "tool_failure",
        "file_collision",
        "test_failure",
        "dependency_error",
        "context_drift",
        "scope_breach",
        "secret_exposure",
        "loop_behavior",
        "model_misroute",
        "playbook_gap",
        "permission_error",
        "git_state_error",
        "environment_error",
        "artifact_error",
        "manual_note"
      ]
    },
    "message": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["surface"],
      "properties": {
        "surface": { "type": "string" },
        "ide": { "type": "string" },
        "agent": { "type": "string" },
        "model": { "type": "string" },
        "session_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "command": { "type": "string" },
    "files_touched": {
      "type": "array",
      "items": { "type": "string" }
    },
    "error_signature": { "type": "string" },
    "raw_excerpt": { "type": "string" },
    "redacted": { "type": "boolean" },
    "suspected_cause": { "type": "string" },
    "action_taken": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["open", "triaged", "queued", "active", "resolved", "ignored", "escalated"]
    },
    "linked_fix": { "type": ["string", "null"] },
    "linked_learning": { "type": ["string", "null"] },
    "next_action": { "type": ["string", "null"] },
    "metadata": { "type": "object" }
  },
  "additionalProperties": true
}
