{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chromatic Mission Packet",
  "type": "object",
  "required": ["mission_id", "objective", "agent_role", "autonomy_level", "confidence_required", "allowed_tools", "stop_conditions", "required_outputs"],
  "properties": {
    "mission_id": {"type": "string"},
    "objective": {"type": "string"},
    "source_intent": {"type": "string"},
    "agent_role": {"type": "string"},
    "model": {"type": "string"},
    "autonomy_level": {"type": "string", "enum": ["L0", "L1", "L2", "L3", "L4", "L5"]},
    "confidence_required": {"type": "number", "minimum": 0, "maximum": 100},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high", "critical"]},
    "allowed_tools": {"type": "array", "items": {"type": "string"}},
    "forbidden_tools": {"type": "array", "items": {"type": "string"}},
    "allowed_paths": {"type": "array", "items": {"type": "string"}},
    "forbidden_paths": {"type": "array", "items": {"type": "string"}},
    "tool_budget": {"type": "object"},
    "stop_conditions": {"type": "array", "items": {"type": "string"}},
    "required_outputs": {"type": "array", "items": {"type": "string"}},
    "evidence_required": {"type": "array", "items": {"type": "string"}}
  }
}
