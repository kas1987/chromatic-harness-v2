openhuman:
  enabled: false
  base_url: http://127.0.0.1:8787
  bearer_token: "${OPENHUMAN_BEARER_TOKEN}"
  default_mode: read_only
  allowed_actions:
    - memory_search
    - context_query
    - health_check
  forbidden_actions:
    - send_email
    - modify_calendar
    - mutate_github
    - delete_files
    - write_chromatic_memory
  max_privacy_class: P2
  human_gate_for_memory_bridge: true
