CHROMATIC_ENV=local
CHROMATIC_LOG_LEVEL=info
CHROMATIC_DB_PATH=./06_DATA/chromatic.sqlite
LANGSMITH_TRACING=false

# Frontier providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Google Gemini (router google_adapter) — adapter disabled if unset
GOOGLE_API_KEY=
# Kimi / Moonshot AI (router kimi_adapter, default for coding routes) — adapter disabled if unset
MOONSHOT_API_KEY=

# Brokers
OPENROUTER_API_KEY=
FEATHERLESS_API_KEY=

# Sidecar
OPENHUMAN_BEARER_TOKEN=
OPENHUMAN_ENABLED=false

# WebSocket multi-instance (optional)
REDIS_URL=
CONSOLE_INSTANCE_URLS=http://localhost:3030

# GitHub / MCP
GITHUB_TOKEN=
