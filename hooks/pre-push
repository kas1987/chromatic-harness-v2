#!/usr/bin/env bash
# Full local CI gate at push time — mirrors .github/workflows/ci.yml (Linux job).
# Runs ruff + guards + mypy, then chains to any pre-existing pre-push (the global
# E2E gate) so nothing is lost. pytest is skipped here because the chained global
# hook already runs the harness E2E suite. Bypass: git push --no-verify.
set -euo pipefail

python scripts/ci_local.py --stage pre-push --skip pytest

# Chain to the previous pre-push hook if the installer preserved one.
PRIOR="$(git rev-parse --git-path hooks/pre-push.prior 2>/dev/null || echo '')"
if [ -n "$PRIOR" ] && [ -x "$PRIOR" ]; then
  exec "$PRIOR" "$@"
fi
