{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chromatic Visual Node Registry",
  "type": "object",
  "required": ["version", "project", "nodes", "edges"],
  "properties": {
    "version": {"type": "string"},
    "project": {"type": "string"},
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "type", "layer"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-zA-Z0-9_-]+$"},
          "label": {"type": "string"},
          "type": {"type": "string"},
          "layer": {"type": "integer", "minimum": 0},
          "owner": {"type": "string"},
          "source_file": {"type": "string"}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 2,
        "items": {"type": "string"}
      }
    }
  }
}
