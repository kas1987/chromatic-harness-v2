{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chromatic Repo Role Registry",
  "type": "object",
  "required": ["schema_version", "authority_root", "repos"],
  "properties": {
    "schema_version": {"type": "integer"},
    "updated_at": {"type": "string"},
    "authority_root": {"type": "string"},
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["repo", "role", "status", "owns", "forbidden"],
        "properties": {
          "repo": {"type": "string"},
          "role": {"type": "string"},
          "status": {"type": "string"},
          "owns": {"type": "array", "items": {"type": "string"}},
          "supports": {"type": "array", "items": {"type": "string"}},
          "forbidden": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
