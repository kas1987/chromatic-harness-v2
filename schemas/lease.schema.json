{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chromatic-harness.local/schemas/lease.schema.json",
  "title": "Chromatic Harness Lease",
  "type": "object",
  "required": ["lease_id", "task_id", "owner_agent", "resources", "mode", "risk_tier", "status", "created_at", "expires_at", "rollback_plan"],
  "properties": {
    "lease_id": {"type": "string", "minLength": 8},
    "task_id": {"type": "string", "minLength": 1},
    "owner_agent": {"type": "string", "minLength": 1},
    "resources": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "mode": {"type": "string", "enum": ["read", "write", "exclusive", "verify"]},
    "risk_tier": {"type": "string", "enum": ["T0", "T1", "T2", "T3", "T4"]},
    "status": {"type": "string", "enum": ["active", "released", "expired", "revoked", "failed"]},
    "created_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": "string", "format": "date-time"},
    "heartbeat_at": {"type": "string", "format": "date-time"},
    "rollback_plan": {"type": "string", "minLength": 1},
    "metadata": {"type": "object"}
  },
  "additionalProperties": false
}
