{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chromatic Harness Event",
  "type": "object",
  "required": [
    "event_id",
    "timestamp",
    "task_id",
    "agent",
    "model",
    "event_type",
    "confidence_score",
    "risk_level",
    "result"
  ],
  "properties": {
    "event_id": {"type": "string"},
    "timestamp": {"type": "string", "format": "date-time"},
    "task_id": {"type": "string"},
    "agent": {"type": "string"},
    "model": {"type": "string"},
    "event_type": {
      "type": "string",
      "enum": ["observe", "classify", "score", "dispatch", "execute", "validate", "record", "halt", "incident"]
    },
    "confidence_score": {"type": "number", "minimum": 0, "maximum": 100},
    "risk_level": {"type": "string", "enum": ["low", "medium", "high", "critical", "unknown"]},
    "tools_used": {"type": "array", "items": {"type": "string"}},
    "files_touched": {"type": "array", "items": {"type": "string"}},
    "duration_ms": {"type": "integer", "minimum": 0},
    "result": {"type": "string", "enum": ["passed", "failed", "blocked", "halted", "partial"]},
    "notes": {"type": "string"}
  }
}
