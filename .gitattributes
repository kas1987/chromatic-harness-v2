* text=auto

# Git hooks execute under bash; a CRLF shebang ("#!/usr/bin/env bash\r") fails
# on Git Bash. Pin every shipped hook directory to LF regardless of
# core.autocrlf so a Windows checkout can't corrupt them. (pre-commit had
# already drifted to CRLF.) git_hooks/ is the active core.hooksPath; hooks/ is
# copied into .git/hooks by scripts/install_git_hooks.py; .beads/hooks/ can be
# the active core.hooksPath for beads/dolt sync — all three must stay LF.
git_hooks/** text eol=lf
hooks/** text eol=lf
.beads/hooks/** text eol=lf
