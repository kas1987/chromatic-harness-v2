.dolt/
*.db
.beads-credential-key

# Dispatch scaffolding — runtime-only task directories
.dispatch/
*.tsbuildinfo

# Session handoff runtime artifacts (generated per agent session)
.agents/handoffs/latest.json
.agents/logs/
12_HANDOFFS/sessions/*.md
!12_HANDOFFS/sessions/.gitkeep

# Pre-session inventory machine-local paths
config/pre_session/settings.local.yaml
